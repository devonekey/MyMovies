<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.MainActivity">

    <data>

        <variable
            name="viewModel"
            type="com.onekey.mymovies.viewmodel.MovieViewModel" />
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <EditText
            android:id="@+id/activity_main_search_movie_edit_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:hint="찾고자하는 내용을 입력해주세요"
            android:imeOptions="actionSearch"
            android:importantForAutofill="no"
            android:inputType="text"
            android:text="@={viewModel.search}"
            app:layout_constraintBottom_toTopOf="@+id/activity_main_movie_recycler_view"
            app:layout_constraintEnd_toStartOf="@+id/activity_main_search_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <Button
            android:id="@+id/activity_main_search_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/ic_search_accent"
            android:onClick="@{() -> viewModel.onSearchButtonClick()}"
            app:layout_constraintBottom_toBottomOf="@+id/activity_main_search_movie_edit_text"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/activity_main_search_movie_edit_text"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/activity_main_movie_recycler_view"
            onListSet="@{viewModel.movieList}"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/activity_main_search_movie_edit_text" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>